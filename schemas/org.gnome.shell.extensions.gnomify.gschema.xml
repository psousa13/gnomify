<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.gnomify"
          path="/org/gnome/shell/extensions/gnomify/">
    <key name="popup-style" type="s">
      <default>'solid'</default>
      <summary>Popup style</summary>
      <description>Either 'solid' (follows system theme) or 'transparent' (frosted glass).</description>
    </key>
    <key name="transparency" type="d">
      <default>0.6</default>
      <range min="0.1" max="0.95"/>
      <summary>Transparency level</summary>
      <description>Background opacity when transparent style is active (0.1 = almost invisible, 0.95 = nearly solid).</description>
    </key>
  </schema>
</schemalist>
